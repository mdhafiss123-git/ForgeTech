PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/techforge
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=http://localhost:5173

# Optional — password reset emails. If these are left unset, reset links
# are logged to the backend console instead of emailed (handy for local
# dev). Set all three to enable real email delivery, e.g. via Gmail SMTP,
# SendGrid, Mailgun, or any standard SMTP provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TechForge <no-reply@techforge.dev>"
